#!/bin/bash
# Munin plugin voor PHP OPcache stats - per container
# Versie: 1.1.0 - Met interned strings monitoring

PLUGIN_NAME="${0##*/}"
CONTAINER="${PLUGIN_NAME#php_opcache_}"
CONTAINER="${CONTAINER//_/-}"  # Zet underscores terug naar streepjes
SOCKET="/run/php/${CONTAINER}.sock"

# Veilige naam voor Munin (streepjes -> underscores)
SAFE_NAME="${CONTAINER//-/_}"

get_opcache_stats() {
    SCRIPT_NAME=/tmp/opcache-status.php \
    SCRIPT_FILENAME=/tmp/opcache-status.php \
    REQUEST_METHOD=GET \
    cgi-fcgi -bind -connect "$SOCKET" 2>&1 | tail -1
}

# Helper functie voor JSON parsing
parse_json() {
    local json="$1"
    local key="$2"
    
    if command -v jq >/dev/null 2>&1; then
        echo "$json" | jq -r "$key // 0"
    else
        # Fallback naar grep/sed
        local value=$(echo "$json" | grep -o "\"${key}\":[0-9]*" | head -1 | cut -d':' -f2)
        echo "${value:-0}"
    fi
}

# Helper functie voor nested JSON parsing
parse_nested_json() {
    local json="$1"
    local parent="$2"
    local child="$3"
    
    if command -v jq >/dev/null 2>&1; then
        echo "$json" | jq -r ".${parent}.${child} // 0"
    else
        # Fallback naar grep/sed voor nested values
        local value=$(echo "$json" | grep -o "\"${child}\":[0-9]*" | head -1 | cut -d':' -f2)
        echo "${value:-0}"
    fi
}

do_memory_config() {
    local json=$(get_opcache_stats)
    
    # Bereken total memory
    local used_mem=$(parse_nested_json "$json" "memory_usage" "used_memory")
    local free_mem=$(parse_nested_json "$json" "memory_usage" "free_memory")
    local wasted_mem=$(parse_nested_json "$json" "memory_usage" "wasted_memory")
    local total_memory=$((used_mem + free_mem + wasted_mem))
    
    # Gebruik total memory of default 256MB
    if [ "$total_memory" -eq 0 ]; then
        total_memory=268435456
    fi
    
    # Bereken thresholds in bytes (10MB = 10485760, 5MB = 5242880)
    local warn_bytes=10485760   # 10MB
    local crit_bytes=5242880    # 5MB
    local warn_wasted=10485760  # 10MB
    local crit_wasted=52428800  # 50MB
    
    cat <<EOF
graph_title PHP OPcache memory usage - ${CONTAINER}
graph_args --base 1024 -l 0
graph_vlabel bytes
graph_category php-opcache
graph_info OPcache memory usage for ${CONTAINER}
graph_order used free wasted total

used.label Used memory
used.type GAUGE
used.min 0
used.draw AREA
used.colour 44AD4E
used.info Currently used OPcache memory

free.label Free memory
free.type GAUGE
free.min 0
free.draw STACK
free.colour 6BAED6
free.warning ${warn_bytes}:
free.critical ${crit_bytes}:
free.info Available OPcache memory (warning if below 10MB, critical if below 5MB)

wasted.label Wasted memory
wasted.type GAUGE
wasted.min 0
wasted.draw STACK
wasted.colour DD4B39
wasted.warning :${warn_wasted}
wasted.critical :${crit_wasted}
wasted.info Memory wasted due to fragmentation (warning if above 10MB, critical if above 50MB)

total.label Total memory
total.type GAUGE
total.min 0
total.draw LINE2
total.colour 999999
total.info Total OPcache memory available
EOF
}

do_keys_config() {
    local json=$(get_opcache_stats)
    local max_keys=$(parse_nested_json "$json" "opcache_statistics" "max_cached_keys")
    
    # Default waarde als niet gevonden
    if [ "$max_keys" -eq 0 ]; then
        max_keys=16229
    fi
    
    cat <<EOF
graph_title PHP OPcache keys usage - ${CONTAINER}
graph_args -l 0
graph_vlabel keys
graph_category php-opcache
graph_info OPcache keys usage for ${CONTAINER}
graph_order cached free max

cached.label Cached keys
cached.type GAUGE
cached.min 0
cached.draw AREA
cached.colour 44AD4E
cached.info Number of currently cached keys

free.label Free slots
free.type GAUGE
free.min 0
free.draw STACK
free.colour 6BAED6
free.info Available key slots (max - cached)

max.label Max keys (total)
max.type GAUGE
max.min 0
max.draw LINE2
max.colour 999999
max.info Maximum number of keys allowed (opcache.max_accelerated_files)
EOF
}

do_interned_strings_config() {
    local json=$(get_opcache_stats)
    local buffer_size=$(parse_nested_json "$json" "interned_strings_usage" "buffer_size")
    
    # Default waarde als niet gevonden (32MB)
    if [ "$buffer_size" -eq 0 ]; then
        buffer_size=33554432
    fi
    
    # Bereken thresholds in bytes (10% en 5% van buffer_size)
    local warn_bytes=$((buffer_size * 10 / 100))
    local crit_bytes=$((buffer_size * 5 / 100))
    
    cat <<EOF
graph_title PHP OPcache interned strings - ${CONTAINER}
graph_args --base 1024 -l 0
graph_vlabel bytes
graph_category php-opcache
graph_info OPcache interned strings buffer for ${CONTAINER}. Shows when buffer is nearly full.
graph_order used free total

used.label Used memory
used.type GAUGE
used.min 0
used.draw AREA
used.colour 44AD4E
used.info Currently used interned strings memory

free.label Free memory
free.type GAUGE
free.min 0
free.draw STACK
free.colour 6BAED6
free.warning ${warn_bytes}:
free.critical ${crit_bytes}:
free.info Available interned strings memory (warning if below 10%, critical if below 5%)

total.label Total buffer size
total.type GAUGE
total.min 0
total.draw LINE2
total.colour 999999
total.info Total interned strings buffer size (opcache.interned_strings_buffer)
EOF
}

do_memory_values() {
    local json=$(get_opcache_stats)
    
    local used_mem=$(parse_nested_json "$json" "memory_usage" "used_memory")
    local free_mem=$(parse_nested_json "$json" "memory_usage" "free_memory")
    local wasted_mem=$(parse_nested_json "$json" "memory_usage" "wasted_memory")
    local total_mem=$((used_mem + free_mem + wasted_mem))
    
    echo "used.value ${used_mem}"
    echo "free.value ${free_mem}"
    echo "wasted.value ${wasted_mem}"
    echo "total.value ${total_mem}"
}

do_keys_values() {
    local json=$(get_opcache_stats)
    
    local max_keys=$(parse_nested_json "$json" "opcache_statistics" "max_cached_keys")
    local cached_keys=$(parse_nested_json "$json" "opcache_statistics" "num_cached_keys")
    
    # Default waarden als niet gevonden
    [ "$max_keys" -eq 0 ] && max_keys=16229
    
    local free_keys=$((max_keys - cached_keys))
    
    echo "cached.value ${cached_keys}"
    echo "free.value ${free_keys}"
    echo "max.value ${max_keys}"
}

do_interned_strings_values() {
    local json=$(get_opcache_stats)
    
    local buffer_size=$(parse_nested_json "$json" "interned_strings_usage" "buffer_size")
    local used_mem=$(parse_nested_json "$json" "interned_strings_usage" "used_memory")
    local free_mem=$(parse_nested_json "$json" "interned_strings_usage" "free_memory")
    
    # Als buffer_size 0 is, gebruik dan default 32MB
    if [ "$buffer_size" -eq 0 ]; then
        buffer_size=33554432
        # Als we geen data hebben, probeer dan used+free te gebruiken
        if [ "$used_mem" -eq 0 ] && [ "$free_mem" -eq 0 ]; then
            used_mem=0
            free_mem=$buffer_size
        fi
    fi
    
    echo "used.value ${used_mem}"
    echo "free.value ${free_mem}"
    echo "total.value ${buffer_size}"
}

# Main logic
if ! docker ps --format "{{.Names}}" | grep -qx "$CONTAINER"; then
    echo "Container $CONTAINER not found" >&2
    exit 1
fi

if [ ! -S "$SOCKET" ]; then
    echo "Socket $SOCKET not found" >&2
    exit 1
fi

case "$1" in
    config)
        echo "multigraph php_opcache_memory_${SAFE_NAME}"
        do_memory_config
        echo
        echo "multigraph php_opcache_keys_${SAFE_NAME}"
        do_keys_config
        echo
        echo "multigraph php_opcache_interned_strings_${SAFE_NAME}"
        do_interned_strings_config
        ;;
    *)
        echo "multigraph php_opcache_memory_${SAFE_NAME}"
        do_memory_values
        echo
        echo "multigraph php_opcache_keys_${SAFE_NAME}"
        do_keys_values
        echo
        echo "multigraph php_opcache_interned_strings_${SAFE_NAME}"
        do_interned_strings_values
        ;;
esac