#!/bin/bash
# Munin plugin voor PHP OPcache stats - per container
# Versie: 1.0.2

PLUGIN_NAME="${0##*/}"
CONTAINER="${PLUGIN_NAME#php_opcache_}"
CONTAINER="${CONTAINER//_/-}"  # Zet underscores terug naar streepjes
SOCKET="/run/php/${CONTAINER}.sock"

# Veilige naam voor Munin (streepjes -> underscores)
SAFE_NAME="${CONTAINER//-/_}"

get_opcache_stats() {
    SCRIPT_NAME=/tmp/opcache-status.php \
    SCRIPT_FILENAME=/tmp/opcache-status.php \
    REQUEST_METHOD=GET \
    cgi-fcgi -bind -connect "$SOCKET" 2>&1 | tail -1
}

do_memory_config() {
    # Haal total memory op voor percentage berekeningen
    local json=$(get_opcache_stats)
    local total_memory=$(echo "$json" | php -r '
        $data = json_decode(file_get_contents("php://stdin"), true);
        if ($data && isset($data["memory_usage"])) {
            $mu = $data["memory_usage"];
            echo $mu["used_memory"] + $mu["free_memory"] + $mu["wasted_memory"];
        } else {
            echo "268435456";  # Default 256MB
        }
    ')
    
    # Bereken thresholds in bytes (10MB = 10485760, 5MB = 5242880)
    local warn_bytes=10485760   # 10MB
    local crit_bytes=5242880    # 5MB
    local warn_wasted=10485760  # 10MB
    local crit_wasted=52428800  # 50MB
    
    cat <<EOF
graph_title PHP OPcache memory usage - ${CONTAINER}
graph_args --base 1024 -l 0
graph_vlabel bytes
graph_category php_opcache
graph_info OPcache memory usage for ${CONTAINER}
graph_order used free wasted total

used.label Used memory
used.type GAUGE
used.min 0
used.draw AREA
used.colour 44AD4E
used.info Currently used OPcache memory

free.label Free memory
free.type GAUGE
free.min 0
free.draw STACK
free.colour 6BAED6
free.warning ${warn_bytes}:
free.critical ${crit_bytes}:
free.info Available OPcache memory (warning if below 10MB, critical if below 5MB)

wasted.label Wasted memory
wasted.type GAUGE
wasted.min 0
wasted.draw STACK
wasted.colour DD4B39
wasted.warning :${warn_wasted}
wasted.critical :${crit_wasted}
wasted.info Memory wasted due to fragmentation (warning if above 10MB, critical if above 50MB)

total.label Total memory
total.type GAUGE
total.min 0
total.draw LINE2
total.colour 999999
total.info Total OPcache memory available
EOF
}

do_keys_config() {
    local json=$(get_opcache_stats)
    local max_keys=$(echo "$json" | php -r '
        $data = json_decode(file_get_contents("php://stdin"), true);
        echo $data["opcache_statistics"]["max_cached_keys"] ?? 16229;
    ')
    
    # Bereken thresholds als percentages van max_keys
    local warn_percent=10
    local crit_percent=5
    local warn_free=$((max_keys * warn_percent / 100))
    local crit_free=$((max_keys * crit_percent / 100))
    
    cat <<EOF
graph_title PHP OPcache keys usage - ${CONTAINER}
graph_args -l 0
graph_vlabel keys
graph_category php_opcache
graph_info OPcache keys usage for ${CONTAINER}
graph_order cached max free

cached.label Cached keys
cached.type GAUGE
cached.min 0
cached.draw AREA
cached.colour 44AD4E
cached.info Number of currently cached keys

max.label Max keys
max.type GAUGE
max.min 0
max.draw LINE2
max.colour 999999
max.info Maximum number of keys allowed (opcache.max_accelerated_files)

free.label Free slots
free.type GAUGE
free.min 0
free.draw STACK
free.colour 6BAED6
free.warning ${warn_free}:
free.critical ${crit_free}:
free.info Available key slots (warning if below ${warn_percent}%, critical if below ${crit_percent}%)
EOF
}

do_memory_values() {
    local json=$(get_opcache_stats)
    
    echo "$json" | php -r '
        $data = json_decode(file_get_contents("php://stdin"), true);
        if (!$data || !isset($data["memory_usage"])) {
            echo "used.value U\nfree.value U\nwasted.value U\ntotal.value U\n";
            exit(1);
        }
        $mu = $data["memory_usage"];
        $total = $mu["used_memory"] + $mu["free_memory"] + $mu["wasted_memory"];
        
        echo "used.value " . ($mu["used_memory"] ?? 0) . "\n";
        echo "free.value " . ($mu["free_memory"] ?? 0) . "\n";
        echo "wasted.value " . ($mu["wasted_memory"] ?? 0) . "\n";
        echo "total.value " . $total . "\n";
    '
}

do_keys_values() {
    local json=$(get_opcache_stats)
    
    echo "$json" | php -r '
        $data = json_decode(file_get_contents("php://stdin"), true);
        if (!$data || !isset($data["opcache_statistics"])) {
            echo "cached.value U\nmax.value U\nfree.value U\n";
            exit(1);
        }
        $os = $data["opcache_statistics"];
        $max = $os["max_cached_keys"] ?? 16229;
        $cached = $os["num_cached_keys"] ?? 0;
        $free = $max - $cached;
        
        echo "cached.value " . $cached . "\n";
        echo "max.value " . $max . "\n";
        echo "free.value " . $free . "\n";
    '
}

# Main logic
if ! docker ps --format "{{.Names}}" | grep -qx "$CONTAINER"; then
    echo "Container $CONTAINER not found" >&2
    exit 1
fi

if [ ! -S "$SOCKET" ]; then
    echo "Socket $SOCKET not found" >&2
    exit 1
fi

case "$1" in
    config)
        echo "multigraph php_opcache_memory_${SAFE_NAME}"
        do_memory_config
        echo
        echo "multigraph php_opcache_keys_${SAFE_NAME}"
        do_keys_config
        ;;
    *)
        echo "multigraph php_opcache_memory_${SAFE_NAME}"
        do_memory_values
        echo
        echo "multigraph php_opcache_keys_${SAFE_NAME}"
        do_keys_values
        ;;
esac